diff --git a/kernel/sulog/event.c b/kernel/sulog/event.c
--- a/kernel/sulog/event.c
+++ b/kernel/sulog/event.c
@@ -2,8 +2,8 @@
 #include <linux/compat.h>
 #include <linux/cred.h>
 #include <linux/gfp.h>
-#include <linux/minmax.h>
-#include <linux/overflow.h>
+#include <linux/kernel.h>
+#include <linux/version.h>
 #include <linux/sched/signal.h>
 #include <linux/slab.h>
 #include <linux/string.h>
 #include <linux/uaccess.h>

-#include <linux/version.h>
 #if defined(__x86_64__) && LINUX_VERSION_CODE < KERNEL_VERSION(6, 2, 0)
 #include <linux/mm.h>
 #endif
+
+/* Linux 4.19: minmax.h does not exist; min/min_t live in kernel.h. */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(4, 18, 0)
+#include <linux/overflow.h>
+#endif
+
+/* ARM TBI / untagged pointers are not available on 4.19. */
+#ifndef untagged_addr
+#define untagged_addr(addr) (addr)
+#endif
+
+/*
+ * strncpy_from_user_nofault arrived in ~5.8. On 4.19 approximate it with
+ * pagefaults disabled around strncpy_from_user.
+ */
+#if LINUX_VERSION_CODE < KERNEL_VERSION(5, 8, 0)
+static inline long ksu_strncpy_from_user_nofault(char *dst, const void __user *src,
+						 long count)
+{
+	long ret;
+
+	if (unlikely(count <= 0))
+		return 0;
+
+	pagefault_disable();
+	ret = strncpy_from_user(dst, (const char __user *)src, count);
+	pagefault_enable();
+	return ret;
+}
+#define strncpy_from_user_nofault ksu_strncpy_from_user_nofault
+#endif
