diff --git a/kernel/selinux/rules.c b/kernel/selinux/rules.c
--- a/kernel/selinux/rules.c
+++ b/kernel/selinux/rules.c
@@ -16,9 +16,13 @@
 #include "linux/lsm_audit.h" // IWYU pragma: keep
 #include "xfrm.h"
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
 struct selinux_policy *backup_sepolicy;
-
 #define SELINUX_POLICY_INSTEAD_SELINUX_SS
+#else
+/* Linux 4.19 keeps the active policy in selinux_state.ss. */
+static DEFINE_MUTEX(ksu_rules);
+#endif
 
 #define ALL NULL
 
@@ -44,7 +48,9 @@ static void reset_avc_cache()
 
 void apply_kernelsu_rules()
 {
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     struct selinux_policy *pol, *old_pol = selinux_state.policy;
+#endif
     struct policydb *db;
 
     if (!getenforce()) {
@@ -53,5 +59,6 @@ void apply_kernelsu_rules()
     }
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     mutex_lock(&selinux_state.policy_mutex);
     backup_sepolicy =
         ksu_dup_sepolicy(rcu_dereference_protected(old_pol, lockdep_is_held(&selinux_state.policy_mutex)));
@@ -83,5 +90,9 @@ void apply_kernelsu_rules()
 
     db = &pol->policydb;
+#else
+    mutex_lock(&ksu_rules);
+    db = &selinux_state.ss->policydb;
+#endif
 
     ksu_type(db, KERNEL_SU_DOMAIN, "domain");
     ksu_permissive(db, KERNEL_SU_DOMAIN);
@@ -143,13 +154,19 @@ void apply_kernelsu_rules()
     ksu_allow(db, "system_server", KERNEL_SU_DOMAIN, "process", "getpgid");
     ksu_allow(db, "system_server", KERNEL_SU_DOMAIN, "process", "sigkill");
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     rcu_assign_pointer(selinux_state.policy, pol);
     synchronize_rcu();
     ksu_destroy_sepolicy(old_pol);
+#endif
 
     reset_avc_cache();
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
 out_unlock:
     mutex_unlock(&selinux_state.policy_mutex);
+#else
+    mutex_unlock(&ksu_rules);
+#endif
 }
 
 #define KSU_SEPOLICY_MAX_BATCH_SIZE (8U * 1024U * 1024U)
@@ -335,7 +352,9 @@ static int apply_one_sepolicy_cmd(struct policydb *db, const struct sepol_data *
 
 int handle_sepolicy(void __user *user_data, u64 data_len)
 {
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     struct selinux_policy *pol, *old_pol;
+#endif
     struct policydb *db;
     struct sepol_batch_cursor cursor;
     u8 *payload;
@@ -365,6 +384,7 @@ int handle_sepolicy(void __user *user_data, u64 data_len)
         pr_info("SELinux permissive or disabled when handle policy!\n");
     }
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     mutex_lock(&selinux_state.policy_mutex);
 
     old_pol = selinux_state.policy;
@@ -377,6 +397,10 @@ int handle_sepolicy(void __user *user_data, u64 data_len)
         goto out_unlock;
     }
     db = &pol->policydb;
+#else
+    mutex_lock(&ksu_rules);
+    db = &selinux_state.ss->policydb;
+#endif
 
     cursor.cur = payload;
     cursor.end = payload + (size_t)data_len;
@@ -419,18 +443,29 @@ int handle_sepolicy(void __user *user_data, u64 data_len)
         cmd_index++;
     }
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     rcu_assign_pointer(selinux_state.policy, pol);
     synchronize_rcu();
     ksu_destroy_sepolicy(old_pol);
+#endif
 
     reset_avc_cache();
     ret = success_cmd_count;
     goto out_unlock;
 
 out_drop_new_policy:
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     ksu_destroy_sepolicy(pol);
+#else
+    /* Earlier commands were applied in place, so invalidate cached denials. */
+    reset_avc_cache();
+#endif
 out_unlock:
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
     mutex_unlock(&selinux_state.policy_mutex);
+#else
+    mutex_unlock(&ksu_rules);
+#endif
 out_free:
     kvfree(payload);
 
diff --git a/kernel/selinux/sepolicy.c b/kernel/selinux/sepolicy.c
--- a/kernel/selinux/sepolicy.c
+++ b/kernel/selinux/sepolicy.c
@@ -840,6 +840,7 @@ bool ksu_genfscon(struct policydb *db, const char *fs_name, const char *path, con
 
 // ======== sepolicy ========
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
 void ksu_destroy_sepolicy(struct selinux_policy *pol)
 {
     policydb_destroy(&pol->policydb);
@@ -908,3 +909,4 @@ out_free_data:
 
     return ERR_PTR(ret);
 }
+#endif
